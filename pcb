#!/usr/bin/env python3
"""
PCB 走线寄生电感计算器 — 交互式 Matplotlib GUI

功能
----
- 5 个参数滑块 + 文本框（联动输入）
- 实时更新 5 张图表：
    ① 四种配置环路电感对比柱状图
    ② 环路电感 vs 边到边间距（扫描 + 当前工作点）
    ③ 环路电感 vs 走线长度（扫描 + 当前工作点）
    ④ 四种配置环路电感 vs 频率（10 kHz – 100 MHz）
    ⑤ 四种配置环路阻抗 |Z| vs 频率（含集肤效应电阻，log-log）
- 四种配置：并排自由 / 并排+地面 / 叠层自由 / 叠层+地面
- 右侧结果面板（并排 + 叠层对比）

公式
----
自感    : Lorenz-Young（矩形截面）
互感    : Neumann（平行等长导体）
地面修正: 镜像法（Image Method）
集肤效应: "空心矩形"截面模型
"""

import math
import numpy as np
import matplotlib
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from matplotlib.widgets import Slider, Button, TextBox

matplotlib.rcParams.update({
    "font.sans-serif": [
        "PingFang SC", "STHeiti", "Hiragino Sans GB",
        "Microsoft YaHei", "SimHei", "DejaVu Sans",
    ],
    "axes.unicode_minus": False,
})

# ─────────────────────────────────────────────────────────────────────────────
# 物理常数
# ─────────────────────────────────────────────────────────────────────────────

MU0     = 4 * math.pi * 1e-7   # 真空磁导率 H/m
RHO_CU  = 1.724e-8              # 铜电阻率 Ω·m (20 °C)
F_MIN   = 1e4                   # 频率扫描起点  10 kHz
F_MAX   = 1e8                   # 频率扫描终点  100 MHz
N_FREQ  = 300                   # 频率扫描点数

# ─────────────────────────────────────────────────────────────────────────────
# 电感核心公式（标量）
# ─────────────────────────────────────────────────────────────────────────────

def _self_L(l, w, t):
    """Lorenz-Young 公式（矩形截面直导体，SI 单位）"""
    gmd = w + t
    return (MU0 * l) / (2 * math.pi) * (
        math.log(2 * l / gmd) + 0.5 + 0.2235 * gmd / l
    )


def _neumann(l, d):
    """Neumann 互感（两平行等长导体，SI 单位）"""
    hyp = math.sqrt(l * l + d * d)
    return (MU0 / (2 * math.pi)) * (l * math.log((l + hyp) / d) - hyp + d)


# ─────────────────────────────────────────────────────────────────────────────
# 向量化版（供扫描计算）
# ─────────────────────────────────────────────────────────────────────────────

def _self_L_v(l, w, t):
    gmd = w + t
    return (MU0 * l) / (2 * np.pi) * (
        np.log(2 * l / gmd) + 0.5 + 0.2235 * gmd / l
    )


def _neumann_v(l, d):
    hyp = np.sqrt(l * l + d * d)
    return (MU0 / (2 * np.pi)) * (l * np.log((l + hyp) / d) - hyp + d)


# ─────────────────────────────────────────────────────────────────────────────
# 并排走线：完整计算
# ─────────────────────────────────────────────────────────────────────────────

def compute(length_mm, width_mm, thickness_mm, edge_to_edge_mm, dielectric_mm):
    """并排走线，返回 dict，所有电感单位 nH"""
    l   = length_mm       * 1e-3
    w   = width_mm        * 1e-3
    t   = thickness_mm    * 1e-3
    s   = edge_to_edge_mm * 1e-3
    h   = dielectric_mm   * 1e-3
    dcc = w + s

    L    = _self_L(l, w, t)
    M    = _neumann(l, dcc)
    Lloop = 2 * (L - M)

    Mimg_s   = _neumann(l, 2 * h)
    Leff     = L - Mimg_s
    Mimg_c   = _neumann(l, math.sqrt(dcc * dcc + 4 * h * h))
    Meff     = M - Mimg_c
    LloopGnd = 2 * (Leff - Meff)

    nH = 1e9
    return dict(
        dcc         = dcc * 1e3,
        L           = L          * nH,
        M           = M          * nH,
        k           = M / L,
        Lloop       = Lloop      * nH,
        Lloop_pcm   = Lloop      * nH / length_mm * 10,
        Leff        = Leff       * nH,
        Meff        = Meff       * nH,
        LloopGnd    = LloopGnd   * nH,
        Lgnd_pcm    = LloopGnd   * nH / length_mm * 10,
        suppression = (1 - LloopGnd / Lloop) * 100,
    )


# ─────────────────────────────────────────────────────────────────────────────
# 叠层走线：两走线在不同层，垂直对齐（水平偏移 = 0）
# ─────────────────────────────────────────────────────────────────────────────

def compute_stacked(length_mm, width_mm, thickness_mm, dielectric_mm):
    """
    叠层走线电感计算。

    dielectric_mm 同时作为：
      · 两层间介质厚度（层间距 h_inter）
      · 底层走线到地平面的距离（h_gnd = h_inter）
    即假设 PCB 叠层对称：底层→地面 = 层间距。

    返回 dict，电感单位 nH。
    """
    l = length_mm    * 1e-3
    w = width_mm     * 1e-3
    t = thickness_mm * 1e-3
    h = dielectric_mm * 1e-3       # 层间距 = 地面距离

    L = _self_L(l, w, t)

    # 两叠层走线的互感（垂直间距 h）
    M_stk = _neumann(l, h)
    Lloop_stk = 2 * (L - M_stk)   # 自由空间环路电感

    # 含地平面（镜像法）
    # 底层走线 B：距地面 h_B = h
    # 顶层走线 A：距地面 h_A = 2h
    h_B, h_A = h, 2 * h

    L_A_eff  = L - _neumann(l, 2 * h_A)          # L - M(l, 4h)
    L_B_eff  = L - _neumann(l, 2 * h_B)          # L - M(l, 2h)
    M_A_imgB = _neumann(l, h_A + h_B)             # M(l, 3h)
    M_AB_eff = M_stk - M_A_imgB

    Lloop_stk_gnd = L_A_eff + L_B_eff - 2 * M_AB_eff

    nH = 1e9
    return dict(
        M_stk           = M_stk          * nH,
        Lloop_stk       = Lloop_stk      * nH,
        Lloop_stk_gnd   = Lloop_stk_gnd  * nH,
        supp_stk        = (1 - Lloop_stk_gnd / Lloop_stk) * 100,
    )


# ─────────────────────────────────────────────────────────────────────────────
# 集肤效应电阻（向量化）
# ─────────────────────────────────────────────────────────────────────────────

def _skin_R_v(l_m, w_m, t_m, f_arr):
    """
    单根矩形走线 AC 电阻 vs 频率（空心矩形截面模型）。

    - 低频：delta >= min(w,t)/2 → 全截面导通 → R_dc
    - 高频：电流在厚度 delta 的环形层流动 → R ∝ sqrt(f)
    """
    delta = np.sqrt(RHO_CU / (np.pi * f_arr * MU0))   # 集肤深度 (m)
    w_in  = np.maximum(w_m - 2 * delta, 0.0)
    t_in  = np.maximum(t_m - 2 * delta, 0.0)
    A_eff = np.maximum(w_m * t_m - w_in * t_in, 1e-30)
    return RHO_CU * l_m / A_eff


# ─────────────────────────────────────────────────────────────────────────────
# 并排：向量化扫描
# ─────────────────────────────────────────────────────────────────────────────

def sweep_gap(length_mm, width_mm, thickness_mm, gap_arr_mm, dielectric_mm):
    l, w, t, h = length_mm*1e-3, width_mm*1e-3, thickness_mm*1e-3, dielectric_mm*1e-3
    dcc  = w + gap_arr_mm * 1e-3
    L    = _self_L(l, w, t)
    M    = _neumann_v(l, dcc)
    Mimg = _neumann(l, 2 * h)
    Leff = L - Mimg
    M2   = _neumann_v(l, np.sqrt(dcc**2 + 4 * h * h))
    nH   = 1e9
    return 2*(L-M)*nH, 2*(Leff-(M-M2))*nH


def sweep_len(length_arr_mm, width_mm, thickness_mm, edge_to_edge_mm, dielectric_mm):
    l, w, t, h = length_arr_mm*1e-3, width_mm*1e-3, thickness_mm*1e-3, dielectric_mm*1e-3
    dcc  = w + edge_to_edge_mm * 1e-3
    L    = _self_L_v(l, w, t)
    M    = _neumann_v(l, dcc)
    Mimg = _neumann_v(l, 2 * h)
    Leff = L - Mimg
    M2   = _neumann_v(l, math.sqrt(dcc*dcc + 4*h*h))
    nH   = 1e9
    return 2*(L-M)*nH, 2*(Leff-(M-M2))*nH


# ─────────────────────────────────────────────────────────────────────────────
# 屏幕尺寸
# ─────────────────────────────────────────────────────────────────────────────

def _screen_inches(max_w=0.90, max_h=0.88):
    try:
        import tkinter as _tk
        r = _tk.Tk(); r.withdraw(); r.update()
        sw, sh = r.winfo_screenwidth(), r.winfo_screenheight()
        dpi = matplotlib.rcParams["figure.dpi"]
        return sw * max_w / dpi, sh * max_h / dpi
    except Exception:
        return 15.0, 10.0


# ─────────────────────────────────────────────────────────────────────────────
# 参数定义
# ─────────────────────────────────────────────────────────────────────────────

DEFAULTS = dict(
    length=100.0, width=0.127, thickness=0.035,
    edge_to_edge=0.127, dielectric=0.100,
)

PARAM_DEFS = [
    ("length",       "走线长度",       "mm",   1.0, 500.0),
    ("width",        "走线宽度",       "mm",  0.05,   5.0),
    ("thickness",    "铜厚",          "mm",  0.01,  0.35),
    ("edge_to_edge", "边到边间距",     "mm",  0.05,   5.0),
    ("dielectric",   "介质厚度(地面)", "mm",  0.01,  3.20),
]

# 结果面板行  (显示标签, dict_key, 单位, 颜色)
RESULT_ROWS = [
    ("中心间距  d_cc",    "dcc",        "mm",    "#8b949e"),
    ("",                  "",           "",      ""),
    ("── 并排走线 ──",    "",           "",      "#444e5a"),
    ("  单根自感  L",     "L",          "nH",    "#58a6ff"),
    ("  两线互感  M",     "M",          "nH",    "#bc8cff"),
    ("  耦合系数  k",     "k",          "",      "#c9d1d9"),
    ("  环路电感(自由)",  "Lloop",      "nH",    "#3fb950"),
    ("  环路电感(地面)",  "LloopGnd",   "nH",    "#f0883e"),
    ("  单位长度(地面)",  "Lgnd_pcm",   "nH/cm", "#8b949e"),
    ("",                  "",           "",      ""),
    ("── 叠层走线 ──",    "",           "",      "#444e5a"),
    ("  层间互感  M_stk", "M_stk",      "nH",    "#bc8cff"),
    ("  环路电感(自由)",  "Lloop_stk",  "nH",    "#4fc3f7"),
    ("  环路电感(地面)",  "Lloop_stk_gnd","nH",  "#ffa657"),
    ("  地面抑制(叠层)",  "supp_stk",   "%",     "#3fb950"),
]


# ─────────────────────────────────────────────────────────────────────────────
# GUI 主类
# ─────────────────────────────────────────────────────────────────────────────

class PCBApp:

    BG  = "#0d1117"
    BP  = "#161b22"
    CG  = "#21262d"
    CB  = "#30363d"
    CT  = "#c9d1d9"
    CM  = "#8b949e"
    CBA = "#58a6ff"    # 蓝：并排自由
    CGR = "#3fb950"    # 绿：并排自由环路
    COR = "#f0883e"    # 橙：并排+地面
    CAC = "#388bfd"    # 滑块
    CPU = "#bc8cff"    # 紫：互感
    CSB = "#4fc3f7"    # 青：叠层自由
    CSG = "#ffa657"    # 浅橙：叠层+地面

    def __init__(self):
        self._updating = False
        self._build_figure()
        self._build_sliders()
        self._build_results_panel()
        self._build_buttons()
        self._update(None)
        self._connect()

    # ── 图形骨架（2 行 × 3 列）────────────────────────────────────────────

    def _build_figure(self):
        w, h = _screen_inches()
        self.fig = plt.figure(figsize=(w, h))
        self.fig.patch.set_facecolor(self.BG)
        self.fig.suptitle(
            "PCB 走线寄生电感计算器  —  并排 / 叠层走线对比",
            color=self.CT, fontsize=12, fontweight="bold", y=0.99,
        )
        gs = gridspec.GridSpec(
            2, 3, figure=self.fig,
            top=0.96, bottom=0.39,
            hspace=0.58, wspace=0.38,
            height_ratios=[1.15, 1.0],
        )
        self.ax_bar = self.fig.add_subplot(gs[0, 0])   # 电感对比柱状图
        self.ax_gap = self.fig.add_subplot(gs[0, 1])   # Lloop vs 间距
        self.ax_len = self.fig.add_subplot(gs[0, 2])   # Lloop vs 长度
        self.ax_fL  = self.fig.add_subplot(gs[1, 0])   # L_loop vs 频率
        self.ax_fZ  = self.fig.add_subplot(gs[1, 1:3]) # |Z| vs 频率（宽）

    def _style(self, ax):
        ax.set_facecolor(self.BP)
        ax.tick_params(colors=self.CM, labelsize=8)
        for sp in ax.spines.values():
            sp.set_color(self.CB)
        ax.xaxis.label.set_color(self.CM)
        ax.yaxis.label.set_color(self.CM)
        ax.title.set_color(self.CT)
        ax.grid(True, color=self.CG, linestyle="--", alpha=0.7, lw=0.6)

    # ── 滑块 + 文本框 ──────────────────────────────────────────────────────

    def _build_sliders(self):
        self.sliders   = {}
        self.textboxes = {}
        SL_X, SL_W  = 0.06, 0.34
        TB_W, TB_GAP = 0.065, 0.006
        row_y = [0.330, 0.287, 0.244, 0.201, 0.158]

        for i, (attr, label, unit, vmin, vmax) in enumerate(PARAM_DEFS):
            sy = row_y[i]
            ax_s = self.fig.add_axes([SL_X, sy, SL_W, 0.026])
            ax_s.set_facecolor(self.BP)
            s = Slider(ax_s, f"{label}  ({unit})", vmin, vmax,
                       valinit=DEFAULTS[attr],
                       color=self.CAC, track_color=self.CG)
            s.label.set_color(self.CT);  s.label.set_fontsize(8)
            s.valtext.set_color(self.CBA); s.valtext.set_fontsize(8)
            self.sliders[attr] = s

            ax_tb = self.fig.add_axes([SL_X + SL_W + TB_GAP, sy, TB_W, 0.026])
            tb = TextBox(ax_tb, "", initial=f"{DEFAULTS[attr]:.4g}",
                         color=self.BP, hovercolor="#1e2a1e")
            tb.text_disp.set_color(self.CBA)
            tb.text_disp.set_fontsize(8.5)
            for sp in ax_tb.spines.values(): sp.set_color(self.CB)
            self.textboxes[attr] = (tb, vmin, vmax)

    # ── 结果面板 ──────────────────────────────────────────────────────────

    def _build_results_panel(self):
        ax = self.fig.add_axes([0.55, 0.082, 0.41, 0.29])
        ax.set_facecolor(self.BP)
        ax.tick_params(left=False, bottom=False, labelleft=False, labelbottom=False)
        for sp in ax.spines.values(): sp.set_color(self.CB)
        ax.set_xlim(0, 1); ax.set_ylim(0, 1)
        self._ax_res = ax
        self._rt = {}

        n = len(RESULT_ROWS)
        step = 0.93 / n
        for i, (label, key, unit, color) in enumerate(RESULT_ROWS):
            y = 0.97 - i * step
            if not label:
                continue
            ax.text(0.03, y, label,
                    color=self.CM if not key else "#6e7681",
                    fontsize=7.2, va="center")
            if key:
                vt = ax.text(0.70, y, "—",
                             color=color, fontsize=7.2,
                             va="center", ha="right", fontfamily="monospace")
                ax.text(0.72, y, unit,
                        color=self.CM, fontsize=6.8, va="center")
                self._rt[key] = vt

    # ── 按钮 + 状态栏 ─────────────────────────────────────────────────────

    def _build_buttons(self):
        ax_rst = self.fig.add_axes([0.06, 0.042, 0.08, 0.034])
        self.btn_reset = Button(ax_rst, "Reset", color=self.BP, hovercolor=self.CB)
        self.btn_reset.label.set_color(self.CT)
        self.btn_reset.label.set_fontsize(8)

        ax_st = self.fig.add_axes([0.06, 0.007, 0.90, 0.018])
        ax_st.axis("off")
        self._status = ax_st.text(0, 0.5, "就绪",
                                  color=self.CM, fontsize=7.5, va="center",
                                  fontfamily="monospace")

    # ── 参数读取 ──────────────────────────────────────────────────────────

    def _read(self):
        return {attr: s.val for attr, s in self.sliders.items()}

    def _sync_tb(self):
        if self._updating: return
        self._updating = True
        for attr, (tb, _, _) in self.textboxes.items():
            tb.set_val(f"{self.sliders[attr].val:.4g}")
        self._updating = False

    def _make_submit(self, attr):
        def _sub(text):
            if self._updating: return
            try:
                tb, vmin, vmax = self.textboxes[attr]
                val = float(np.clip(float(text), vmin, vmax))
                self._updating = True
                self.sliders[attr].set_val(val)
                self._updating = False
            except (ValueError, TypeError): pass
        return _sub

    # ── 核心更新 ──────────────────────────────────────────────────────────

    def _update(self, _val):
        p = self._read()
        try:
            r   = compute(p["length"], p["width"], p["thickness"],
                          p["edge_to_edge"], p["dielectric"])
            rs  = compute_stacked(p["length"], p["width"], p["thickness"],
                                  p["dielectric"])
        except Exception as e:
            self._status.set_text(f"计算错误: {e}")
            self.fig.canvas.draw_idle()
            return

        # ── 刷新结果面板 ────────────────────────────────────────────────
        combined = {**r, **rs}
        fmts = {k: (f"{v:.4f}" if k == "k" else
                    f"{v:.2f}"  if k in ("suppression","supp_stk") else
                    f"{v:.3f}")
                for k, v in combined.items() if isinstance(v, float)}
        for key, txt in self._rt.items():
            if key in fmts: txt.set_text(fmts[key])

        # ── 四种配置 ──────────────────────────────────────────────────────
        CONFIGS = [
            ("并排 自由",  r["Lloop"],          self.CGR, "-"),
            ("并排+地面",  r["LloopGnd"],        self.COR, "-"),
            ("叠层 自由",  rs["Lloop_stk"],      self.CSB, "--"),
            ("叠层+地面",  rs["Lloop_stk_gnd"],  self.CSG, "--"),
        ]

        # ── 图①：电感量对比柱状图 ────────────────────────────────────
        ax = self.ax_bar; ax.cla(); self._style(ax)
        ax.grid(axis="x", color=self.CG, linestyle="--", alpha=0.7, lw=0.6)
        ax.grid(axis="y", visible=False)
        names  = [c[0] for c in CONFIGS]
        vals   = [c[1] for c in CONFIGS]
        colors = [c[2] for c in CONFIGS]
        ax.barh(names[::-1], vals[::-1], color=colors[::-1],
                alpha=0.85, height=0.55)
        vmax = max(vals) if max(vals) > 0 else 1.0
        for nm, vl, cl in zip(names[::-1], vals[::-1], colors[::-1]):
            ax.text(vl + vmax * 0.015, nm, f"{vl:.2f} nH",
                    va="center", fontsize=7.5, color=cl, fontfamily="monospace")
        ax.set_xlim(0, vmax * 1.35)
        ax.set_xlabel("环路电感 (nH)", fontsize=8)
        ax.set_title("四种配置对比", fontsize=9)
        ax.tick_params(axis="y", colors=self.CT, labelsize=8)

        # ── 图②：环路电感 vs 边到边间距 ───────────────────────────────
        ax = self.ax_gap; ax.cla(); self._style(ax)
        gap_arr = np.linspace(0.05, 5.0, 200)
        Lf, Lg = sweep_gap(p["length"], p["width"], p["thickness"],
                           gap_arr, p["dielectric"])
        ax.plot(gap_arr, Lf, color=self.CGR, lw=1.6, label="并排 自由")
        ax.plot(gap_arr, Lg, color=self.COR, lw=1.6, label="并排+地面")
        ax.axvline(p["edge_to_edge"], color=self.CBA,
                   lw=1.2, ls="--", alpha=0.9)
        ax.scatter([p["edge_to_edge"]], [r["Lloop"]],    s=50,
                   color=self.CGR, zorder=5)
        ax.scatter([p["edge_to_edge"]], [r["LloopGnd"]], s=50,
                   color=self.COR, zorder=5)
        ax.set_xlabel("边到边间距 (mm)", fontsize=8)
        ax.set_ylabel("环路电感 (nH)", fontsize=8)
        ax.set_title("并排走线  vs  间距", fontsize=9)
        ax.legend(fontsize=7.5, facecolor=self.BP,
                  labelcolor=self.CT, edgecolor=self.CB, loc="upper right")

        # ── 图③：环路电感 vs 走线长度 ─────────────────────────────────
        ax = self.ax_len; ax.cla(); self._style(ax)
        len_arr = np.linspace(5.0, 500.0, 200)
        Lf, Lg = sweep_len(len_arr, p["width"], p["thickness"],
                           p["edge_to_edge"], p["dielectric"])
        ax.plot(len_arr, Lf, color=self.CGR, lw=1.6, label="并排 自由")
        ax.plot(len_arr, Lg, color=self.COR, lw=1.6, label="并排+地面")
        ax.axvline(p["length"], color=self.CBA, lw=1.2, ls="--", alpha=0.9)
        ax.scatter([p["length"]], [r["Lloop"]],    s=50,
                   color=self.CGR, zorder=5)
        ax.scatter([p["length"]], [r["LloopGnd"]], s=50,
                   color=self.COR, zorder=5)
        ax.set_xlabel("走线长度 (mm)", fontsize=8)
        ax.set_ylabel("环路电感 (nH)", fontsize=8)
        ax.set_title("并排走线  vs  长度", fontsize=9)
        ax.legend(fontsize=7.5, facecolor=self.BP,
                  labelcolor=self.CT, edgecolor=self.CB, loc="upper left")

        # ─────────────────────────────────────────────────────────────────
        # 频率扫描准备
        # ─────────────────────────────────────────────────────────────────
        f_arr  = np.logspace(math.log10(F_MIN), math.log10(F_MAX), N_FREQ)
        l_m    = p["length"]    * 1e-3
        w_m    = p["width"]     * 1e-3
        t_m    = p["thickness"] * 1e-3
        R1     = _skin_R_v(l_m, w_m, t_m, f_arr)   # 单根走线电阻 (Ω)
        R_loop = 2 * R1                              # 环路电阻 = 两根之和

        # ── 图④：环路电感 vs 频率（水平线对比）───────────────────────
        ax = self.ax_fL; ax.cla(); self._style(ax)
        ax.set_xscale("log")
        ax.set_xlim(F_MIN, F_MAX)

        for label, L_nH, color, ls in CONFIGS:
            ax.axhline(L_nH, color=color, lw=1.6, ls=ls)
            # 在曲线右端标注数值
            ax.text(F_MAX * 1.05, L_nH, f" {L_nH:.1f} nH",
                    color=color, fontsize=7, va="center", clip_on=False)

        # 叠层走线标注（层间 = 介质厚度）
        ax.text(F_MIN * 2, rs["Lloop_stk"] * 1.08,
                f"叠层层间={p['dielectric']:.2f} mm",
                color=self.CM, fontsize=7)

        ax.set_xlabel("频率 (Hz)", fontsize=8)
        ax.set_ylabel("环路电感 (nH)", fontsize=8)
        ax.set_title("环路电感  vs  频率", fontsize=9)
        # 手动图例
        from matplotlib.lines import Line2D
        leg_handles = [Line2D([0], [0], color=c[2], lw=1.5, ls=c[3],
                              label=c[0]) for c in CONFIGS]
        ax.legend(handles=leg_handles, fontsize=7, facecolor=self.BP,
                  labelcolor=self.CT, edgecolor=self.CB, loc="upper left")

        # ── 图⑤：环路阻抗 |Z| vs 频率（log-log）───────────────────────
        ax = self.ax_fZ; ax.cla(); self._style(ax)
        ax.set_xscale("log"); ax.set_yscale("log")
        ax.set_xlim(F_MIN, F_MAX)

        omega = 2 * np.pi * f_arr
        Z_all = []
        for label, L_nH, color, ls in CONFIGS:
            Z = np.sqrt(R_loop**2 + (omega * L_nH * 1e-9)**2)   # |Z| (Ω)
            Z_all.append(Z)
            ax.plot(f_arr, Z * 1e3, color=color, lw=1.6, ls=ls,  # mΩ
                    label=f"{label}: {L_nH:.1f} nH")

            # 标记 ωL = R_loop 交叉点（感性主导起始）
            cross_idx = np.where(omega * L_nH * 1e-9 > R_loop)[0]
            if len(cross_idx) > 0:
                ci  = cross_idx[0]
                fc  = f_arr[ci]
                Zc  = float(np.sqrt(R_loop[ci]**2 + (omega[ci] * L_nH * 1e-9)**2))
                ax.scatter([fc], [Zc * 1e3], s=30, color=color,
                           zorder=5, alpha=0.85)

        # 参考线：纯感抗斜率（45° 在 log-log 上）
        L_ref = r["Lloop"]  # 以并排自由空间作参考
        ax.plot(f_arr, omega * L_ref * 1e-9 * 1e3,
                color="#ffffff", lw=0.7, ls=":", alpha=0.35, label="ωL 参考斜率")
        # 纯电阻参考（DC 值）
        R_dc = float(_skin_R_v(l_m, w_m, t_m, np.array([1.0]))[0])
        ax.axhline(2 * R_dc * 1e3, color="#ffffff", lw=0.7, ls=":",
                   alpha=0.35, label=f"R_dc ≈ {2*R_dc*1e3:.1f} mΩ")

        ax.set_xlabel("频率 (Hz)", fontsize=8)
        ax.set_ylabel("|Z|  (mΩ)", fontsize=8)
        ax.set_title(
            f"环路阻抗  vs  频率   ({F_MIN/1e3:.0f} kHz – {F_MAX/1e6:.0f} MHz)",
            fontsize=9,
        )
        ax.legend(fontsize=7.5, facecolor=self.BP,
                  labelcolor=self.CT, edgecolor=self.CB,
                  loc="upper left", ncol=2)

        self._sync_tb()
        self._status.set_text(
            f"并排:  L_free={r['Lloop']:.2f} nH  L_gnd={r['LloopGnd']:.2f} nH  |  "
            f"叠层:  L_free={rs['Lloop_stk']:.2f} nH  L_gnd={rs['Lloop_stk_gnd']:.2f} nH  |  "
            f"k={r['k']:.4f}  d_cc={r['dcc']:.3f} mm"
        )
        self.fig.canvas.draw_idle()

    # ── 重置 ─────────────────────────────────────────────────────────────

    def _on_reset(self, _event):
        for attr, s in self.sliders.items():
            s.eventson = False
            s.set_val(DEFAULTS[attr])
            s.eventson = True
        self._update(None)

    # ── 事件绑定 ──────────────────────────────────────────────────────────

    def _connect(self):
        for s in self.sliders.values():
            s.on_changed(self._update)
        self.btn_reset.on_clicked(self._on_reset)
        for attr in self.textboxes:
            tb, _, _ = self.textboxes[attr]
            tb.on_submit(self._make_submit(attr))

    def show(self):
        plt.show()


